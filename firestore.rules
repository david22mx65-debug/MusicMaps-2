rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Document ID: userId (string)
    // Fields:
    //   - userName: string (required)
    //   - userImage: string (optional, data URI)
    //   - uiTheme: string (required, 'dark' | 'light')
    //   - mapTheme: string (required, 'dark' | 'light')
    //   - language: string (required, 'es' | 'en' | 'pt')
    //   - volume: number (required, 0-1)
    //   - uiStyle: string (required, 'classic' | 'pixel' | 'liquid-glass')
    //   - primaryColor: string (required)
    //   - keepScreenOn: boolean (optional)
    //   - enableBackgroundMode: boolean (optional)
    //   - enableFadeOut: boolean (optional)
    //   - fadeOutDuration: number (optional)
    //   - enableFadeIn: boolean (optional)
    //   - fadeInDuration: number (optional)
    //   - enableCrossfade: boolean (optional)
    //   - crossfadeDuration: number (optional)
    //
    // Collection: /users/{userId}/zones/{zoneId}
    // Document ID: zoneId (string)
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - description: string (optional)
    //   - center: map (required, {lat: number, lng: number})
    //   - radius: number (required, 5-1000)
    //   - music: map (optional, {name: string, url: string, coverUrl: string})
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin') ||
          (request.auth.token.email == "david22mx65@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      let requiredFields = [
        'userName', 'uiTheme', 'mapTheme', 'language', 'volume', 'uiStyle', 'primaryColor',
        'keepScreenOn', 'enableBackgroundMode', 'enableFadeOut', 'fadeOutDuration',
        'enableFadeIn', 'fadeInDuration', 'enableCrossfade', 'crossfadeDuration'
      ];
      return data.keys().hasAll(requiredFields) &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.uiTheme in ['dark', 'light'] &&
             data.mapTheme in ['dark', 'light'] &&
             data.language in ['es', 'en', 'pt'] &&
             data.volume is number && data.volume >= 0 && data.volume <= 1 &&
             data.uiStyle in ['classic', 'pixel', 'liquid-glass'] &&
             data.primaryColor is string && data.primaryColor.size() < 20 &&
             data.keepScreenOn is bool &&
             data.enableBackgroundMode is bool &&
             data.enableFadeOut is bool &&
             data.fadeOutDuration is number &&
             data.enableFadeIn is bool &&
             data.fadeInDuration is number &&
             data.enableCrossfade is bool &&
             data.crossfadeDuration is number &&
             (!('userImage' in data) || (data.userImage is string && data.userImage.size() < 1000000));
    }

    function isValidZone(data) {
      let requiredFields = ['id', 'name', 'center', 'radius'];
      return data.keys().hasAll(requiredFields) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.center is map && data.center.lat is number && data.center.lng is number &&
             data.radius is number && data.radius > 0 && data.radius <= 1000 &&
             (!('description' in data) || (data.description is string && data.description.size() < 500)) &&
             (!('music' in data) || (
               data.music is map &&
               data.music.name is string &&
               data.music.url is string &&
               (!('coverUrl' in data.music) || data.music.coverUrl is string)
             ));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /zones/{zoneId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidZone(request.resource.data);
        allow update: if isOwner(userId) && isValidZone(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
